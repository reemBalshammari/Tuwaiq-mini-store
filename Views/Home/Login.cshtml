@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="row justify-content-center mt-5">

    <div class="col-md-5">

        <div class="card shadow">

            <div class="card-body">

                <h2 class="text-center mb-4">
                    تسجيل الدخول
                </h2>

                <form asp-controller="Home" asp-action="Login" method="post">

                    <div class="mb-3">
                        <label class="form-label">
                            اسم المستخدم
                        </label>

                        <input type="text"
                               name="userName"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            كلمة المرور
                        </label>

                        <input type="password"
                               name="password"
                               class="form-control" />
                    </div>

                    <button type="submit"
                            class="btn btn-success w-100">
                        دخول
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>
