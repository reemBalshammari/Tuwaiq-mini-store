@model List<mini_store.Models.Product>

@{
    Layout = "_DashboardLayout";
}

<div class="container mt-4" dir="rtl">

    <h2 class="text-center mb-4">لوحة التحكم لإضافة المنتجات</h2>

    <div class="card mt-4">
        <div class="card-header">
            إضافة منتج جديد
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label">اسم المنتج</label>
                    <input name="Name" class="form-control" placeholder="ادخل اسم المنتج" />
                    <span class="text-danger" data-valmsg-for="Name"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">سعر المنتج</label>
                    <input name="Price" type="number" step="0.01" class="form-control" placeholder="ادخل سعر المنتج" />
                    <span class="text-danger" data-valmsg-for="Price"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">صورة المنتج</label>
                    <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label">الفئة</label>

                    <select name="CategoryId" class="form-select">
                        <option value="">اختر الفئة</option>

                        @foreach (var item in ViewBag.categories)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-success">
                    حفظ المنتج
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    إلغاء وعودة
                </a>

            </form>

        </div>
    </div>

    <br />

    <table class="table table-bordered text-center">

        <thead>
            <tr>
                <th>#</th>
                <th>اسم المنتج</th>
                <th>السعر</th>
                <th>الصورة</th>
                <th>إجراء</th>
            </tr>
        </thead>

        <tbody>

            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="5">لا توجد بيانات</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Price</td>

                        <td>
                            <img src="~/images/@item.Image"
                                 alt="@item.Name"
                                 width="70"
                                 height="70"
                                 class="rounded"
                                 style="object-fit:cover;" />
                        </td>

                        <td>
                            <a href="/Products/Edit/@item.Id" class="btn btn-warning btn-sm">
                                تعديل
                            </a>

                            <a href="/Products/Delete/@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('هل أنت متأكد من حذف هذا المنتج؟')">
                                حذف
                            </a>
                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
