@model List<mini_store.Models.Categories>
    @{
    Layout = "_DashboardLayout";
}

<div class="container mt-4" dir="rtl">

    <h1 class="text-center">إضافة الفئات</h1>

    <div class="card mt-4">
        <div class="card-header">
            <h5>إضافة فئة جديدة</h5>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">اسم الفئة</label>
                    <input type="text" name="Name" class="form-control" placeholder="ادخل اسم الفئة" />
                </div>

                <div class="mb-3">
                    <label class="form-label">الأيقونة</label>
                    <input type="text" name="Icon" class="form-control" placeholder="ادخل كود الأيقونة" />
                </div>

                <button type="submit" class="btn btn-success">حفظ الفئة</button>
                <a href="/Home/Index" class="btn btn-light">إلغاء وعودة</a>
            </form>
        </div>
    </div>

    <div class="card mt-5">
        <div class="card-body">
            <table class="table table-bordered text-center">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>اسم الفئة</th>
                        <th>أيقونة الفئة</th>
                        <th>إجراء</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || Model.Count == 0)
                    {
                        <tr>
                            <td colspan="4">لا توجد بيانات</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Icon</td>
                                <td>
                                    <a href="/Categories/Edit/@item.Id" class="btn btn-warning btn-sm">✏️</a>
                                    <a href="/Categories/Delete/@item.Id" class="btn btn-danger btn-sm">🗑️</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
