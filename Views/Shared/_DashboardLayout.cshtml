@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    bool en = CultureInfo.CurrentUICulture.Name == "en-US";
    string dir = en ? "ltr" : "rtl";
}

<!DOCTYPE html>
<html lang="@(en ? "en" : "ar")" dir="@dir">
<head>
    <meta charset="utf-8" />
    <title>@(en ? "Store System" : "نظام المتجر")</title>

    @if (en)
    {
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    }
    else
    {
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    }

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body { background-color: #f8f4f2; }

        .menu-btn {
            position: fixed;
            top: 20px;
            @(en ? "left" : "right"): 20px;
            z-index: 2000;
            background-color: #1f2937;
            color: white;
            border: none;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 24px;
        }

        .lang-btns {
            position: fixed;
            top: 20px;
            @(en ? "right" : "left"): 20px;
            z-index: 2000;
        }

        .sidebar {
            width: 230px;
            height: 100vh;
            background-color: #1f2937;
            color: white;
            position: fixed;
            @(en ? "left" : "right"): -250px;
            top: 0;
            padding: 80px 15px 25px;
            transition: .3s;
            z-index: 1500;
        }

        .sidebar.active {
            @(en ? "left" : "right"): 0;
        }

        .sidebar h4 { text-align: center; margin-bottom: 30px; }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 8px;
        }

        .sidebar a:hover { background-color: #374151; }

        .content { padding: 80px 25px 25px; }

        .footer {
            text-align: center;
            margin-top: 40px;
            color: #777;
        }
    </style>
</head>

<body>

    <div class="lang-btns">
        <form asp-controller="Language" asp-action="SetLanguage" method="post" style="display:inline;">
            <input type="hidden" name="culture" value="en-US" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
            <button type="submit" class="btn btn-outline-secondary btn-sm">English</button>
        </form>

        <form asp-controller="Language" asp-action="SetLanguage" method="post" style="display:inline;">
            <input type="hidden" name="culture" value="ar" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
            <button type="submit" class="btn btn-outline-secondary btn-sm">Arabic</button>
        </form>
    </div>

    <button class="menu-btn" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>

    <div class="sidebar" id="sidebar">
        <h4><i class="bi bi-shop"></i> @(en ? "Store System" : "نظام المتجر")</h4>

        <a href="/"><i class="bi bi-house"></i> @(en ? "Home" : "الرئيسية")</a>
        <a href="/Categories"><i class="bi bi-tags"></i> @(en ? "Categories" : "الفئات")</a>
        <a href="/Products"><i class="bi bi-box-seam"></i> @(en ? "Products" : "المنتجات")</a>
        <a href="#"><i class="bi bi-graph-up"></i> @(en ? "Reports" : "التقارير")</a>
        <a href="/"><i class="bi bi-box-arrow-right"></i> @(en ? "Logout" : "تسجيل الخروج")</a>
    </div>

    <div class="content">
        @RenderBody()

        <div class="footer">
            © 2026 - سيدره | حيث تزهر المشاعر
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("active");
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>
