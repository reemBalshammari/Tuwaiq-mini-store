<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>نظام المتجر</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f8f4f2;
        }

        .menu-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 2000;
            background-color: #1f2937;
            color: white;
            border: none;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 24px;
        }

        .sidebar {
            width: 230px;
            height: 100vh;
            background-color: #1f2937;
            color: white;
            position: fixed;
            right: -250px;
            top: 0;
            padding: 80px 15px 25px;
            transition: 0.3s;
            z-index: 1500;
        }

        .sidebar.active {
            right: 0;
        }

        .sidebar h4 {
            text-align: center;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 8px;
        }

        .sidebar a:hover {
            background-color: #374151;
        }

        .content {
            padding: 80px 25px 25px;
        }

        .footer {
            text-align: center;
            margin-top: 40px;
            color: #777;
        }
    </style>
</head>

<body>

    <button class="menu-btn" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
    </button>

    <div class="sidebar" id="sidebar">
        <h4>نظام المتجر</h4>

        <a href="/"><i class="bi bi-house"></i> الرئيسية</a>
        <a href="/Categories"><i class="bi bi-tags"></i> الفئات</a>
        <a href="/Products"><i class="bi bi-box-seam"></i> المنتجات</a>
        <a href="#"><i class="bi bi-cart"></i> الطلبات</a>
        <a href="#"><i class="bi bi-people"></i> العملاء</a>
        <a href="/"><i class="bi bi-box-arrow-right"></i> تسجيل الخروج</a>
    </div>

    <div class="content">
        @RenderBody()

        <div class="footer">
            © 2026 - سيدره | حيث تزهر المشاعر
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("active");
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>