@model mini_store.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">

                <h2 class="text-center mb-4">تسجيل الدخول</h2>

                <form asp-action="Login" method="post">

                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">كلمة المرور</label>
                        <input asp-for="Password" class="form-control" />
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">
                            تذكرني في المرة القادمة
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        دخول
                    </button>

                </form>

<div class="text-center mt-3">
    <a asp-controller="Account" asp-action="Register">
        ليس لديك حساب؟ أنشئ حسابًا جديدًا من هنا
    </a>
</div>

</div>
</div>
</div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
